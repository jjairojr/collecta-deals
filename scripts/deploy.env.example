# Copy to scripts/deploy.env (gitignored) and fill in.
# Used by scripts/sync-up.sh, scripts/sync-down.sh, scripts/seed-prod.sh.

# Public URL of the prod opdeals service (no trailing slash).
OPDEALS_URL=https://your-app.up.railway.app

# Same secret set as the ADMIN_TOKEN env var on the Railway service.
ADMIN_TOKEN=change-me

# Railway service name (matches railway.toml / the dashboard).
RAILWAY_SERVICE=opdeals
