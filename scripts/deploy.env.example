# Copy to scripts/deploy.env (gitignored) and fill in.
# Used by scripts/sync-up.sh, scripts/sync-down.sh, scripts/seed-prod.sh.

# Public URL of the prod opdeals service (no trailing slash).
OPDEALS_URL=https://collecta-deals-production.up.railway.app

# Same secret set as the ADMIN_TOKEN env var on the Railway service.
ADMIN_TOKEN=change-me

# Railway service name (matches the dashboard).
RAILWAY_SERVICE=collecta-deals

# Optional: the volume whose files the sync scripts read/write. Leave blank to
# auto-detect the volume mounted at /app/data.
RAILWAY_VOLUME=
